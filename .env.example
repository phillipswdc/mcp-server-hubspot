# Required: which HubSpot account this server connects to.
# No default — the server refuses to start without this set explicitly.
HUBSPOT_ENV=sandbox

# HubSpot private app access tokens, one per environment.
# Set the one(s) you need for your active HUBSPOT_ENV.
HUBSPOT_TOKEN_SANDBOX=your-sandbox-token
HUBSPOT_TOKEN_PRODUCTION=your-production-token

# Legacy fallback (only used if the env-specific token above isn't set).
# Leave commented unless you're migrating from a single-token setup.
# HUBSPOT_ACCESS_TOKEN=your-legacy-token

# Optional: Ollama for LLM-enhanced property categorization, audit summaries, etc.
# When unset OR Ollama is unreachable, LLM-aware tools fall back to rule-based output.
# Default model is gemma4:e4b (2026 release; 4.5B effective params, 9.6GB).
# For lighter footprint use gemma4:e2b (2.3B effective params, 7.2GB).
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:e4b
